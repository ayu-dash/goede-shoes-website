<%- include('../partials/dashboard-head') %>

<div class="admin-panel">
  <div class="admin-panel-header">
    <h3 class="admin-panel-title">Riwayat Pesanan</h3>
    <p class="admin-panel-subtitle">DAFTAR PESANAN SELESAI & DIBATALKAN</p>
  </div>

  <div class="admin-table-container">
    <table class="admin-table">
      <thead>
        <tr>
          <th>ORDER ID</th>
          <th>CUSTOMER</th>
          <th>TGL SELESAI</th>
          <th>LAYANAN</th>
          <th>TOTAL</th>
          <th>STATUS AKHIR</th>
          <th>AKSI</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <tr>
              <td style="font-weight: 700; color: var(--navy);"><%= order.orderId %></td>
              <td>
                <span class="table-client-name"><%= order.user ? order.user.name : 'Unknown' %></span>
              </td>
              <td>
                <span class="table-client-sub">
                    <%= new Date(order.updatedAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </span>
              </td>
              <td>
                <span class="badge badge-layanan-blue" style="font-size: 10px;">
                    <%= order.items[0]?.serviceType %>
                </span>
              </td>
              <td>
                <span style="font-weight: 600;">Rp <%= order.totalPrice.toLocaleString('id-ID') %></span>
              </td>
              <td>
                <% if (order.status === 'completed') { %>
                  <span class="badge badge-completed">SELESAI</span>
                <% } else { %>
                  <span class="badge" style="background: #fee2e2; color: #991b1b; border: 1px solid #fecaca;">DIBATALKAN</span>
                <% } %>
              </td>
              <td>
                <a href="/staff/order/<%= order._id %>" class="btn btn-outline btn-sm" style="padding: 4px 12px; font-size: 11px;">
                    Detail
                </a>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="7" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
              Belum ada riwayat pesanan.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/dashboard-foot') %>

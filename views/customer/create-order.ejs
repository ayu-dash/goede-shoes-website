<%- include('../partials/dashboard-head') %>
<script src="https://app.sandbox.midtrans.com/snap/snap.js" data-client-key="<%= midtransClientKey %>"></script>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div>
      <h1 class="page-title">Buat Pesanan Baru</h1>
      <p class="page-subtitle">
        Berikan perawatan terbaik untuk koleksi sepatu Anda dengan standar presisi
        GOEDE.
      </p>
    </div>
  </div>

  <div id="goede-dynamic-data" 
       data-mainservices="<%= JSON.stringify(mainServices) %>" 
       data-addons="<%= JSON.stringify(addOns) %>" 
       data-shipping-rate="<%= settings.shippingRatePerKm || 5000 %>"
       style="display: none;"></div>

  <script>
    try {
      const dataContainer = document.getElementById("goede-dynamic-data");
      const msData = JSON.parse(dataContainer.dataset.mainservices || "[]");
      const aoData = JSON.parse(dataContainer.dataset.addons || "[]");

      const dynamicServices = {};
      const dynamicAddons = {};
      const dynamicMetadata = {};

      msData.forEach(s => {
         dynamicServices[s.name] = s.price;
         dynamicMetadata[s.name] = { price: s.price, timeMin: s.estimatedTimeMin, timeMax: s.estimatedTimeMax, timeUnit: s.estimatedTimeUnit };
      });
      
      aoData.forEach(s => {
         dynamicAddons[s.name] = s.price;
         dynamicMetadata[s.name] = { price: s.price, timeMin: s.estimatedTimeMin, timeMax: s.estimatedTimeMax, timeUnit: s.estimatedTimeUnit };
      });

      window.DYNAMIC_PRICES = {
        SERVICES: dynamicServices,
        ADDONS: dynamicAddons,
        PICKUP_FEE: parseInt(dataContainer.dataset.shippingRate),
        DELIVERY_FEE: parseInt(dataContainer.dataset.shippingRate)
      };
      window.DYNAMIC_SERVICES = dynamicMetadata;
    } catch (err) {
      console.error("Error parsing dynamic data", err);
    }
  </script>

  <!-- TEMPLATE UNTUK JS (Hidden) -->
  <div id="shoe-item-template" style="display:none;">
    <div class="shoe-item">
      <div class="shoe-item-header">
        <span class="shoe-item-label">Item {INDEX}</span>
        <button type="button" class="shoe-item-remove" data-item="{INDEX}">
          Hapus
        </button>
      </div>
      <div class="shoe-item-fields">
        <div class="form-group">
          <label class="form-label form-label--upper">Nama Sepatu</label>
          <input type="text" class="form-input shoe-name" placeholder="Masukkan nama sepatu" />
        </div>
        <div class="form-group">
          <label class="form-label form-label--upper">Jenis Layanan</label>
          <select class="form-input form-select service-type" required>
            <option value="" disabled selected>-- Pilih Layanan --</option>
            <% mainServices.forEach(s => { %>
              <option value="<%= s.name %>"><%= s.name %> - Rp <%= s.price.toLocaleString("id-ID") %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <% if (addOns && addOns.length > 0) { %>
      <div class="form-group">
        <label class="form-label form-label--upper">Layanan Tambahan (Add-Ons)</label>
        <div class="addon-tags">
          <% addOns.forEach(s => { %>
            <label class="addon-tag"><input type="checkbox" value="<%= s.name %>" /> <%= s.name %> (+Rp <%= s.price.toLocaleString("id-ID") %>)</label>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <div class="order-layout">
    <!-- LEFT: FORM -->
    <div class="order-form-col">
      <!-- DETAIL ITEM SEPATU -->
      <div class="order-section">
        <div class="order-section-header">
          <h3 class="order-section-title">Detail Item Sepatu</h3>
          <button type="button" class="btn btn-primary btn-sm" id="btn-add-shoe">
            <i class="fa-solid fa-plus"></i> Tambah Sepatu
          </button>
        </div>

        <!-- Item 1 -->
        <div class="shoe-item" id="shoe-item-1">
          <div class="shoe-item-header">
            <span class="shoe-item-label">Item 1</span>
            <button type="button" class="shoe-item-remove" data-item="1">
              Hapus
            </button>
          </div>
          <div class="shoe-item-fields">
            <div class="form-group">
              <label class="form-label form-label--upper">Nama Sepatu</label>
              <input type="text" class="form-input shoe-name" placeholder="Masukkan nama sepatu" />
            </div>
            <div class="form-group">
              <label class="form-label form-label--upper">Jenis Layanan</label>
              <select class="form-input form-select service-type" required>
                <option value="" disabled selected>-- Pilih Layanan --</option>
                <% mainServices.forEach(s => { %>
                  <option value="<%= s.name %>"><%= s.name %> - Rp <%= s.price.toLocaleString("id-ID") %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <% if (addOns && addOns.length > 0) { %>
          <div class="form-group">
            <label class="form-label form-label--upper">Layanan Tambahan (Add-Ons)</label>
            <div class="addon-tags">
              <% addOns.forEach(s => { %>
                <label class="addon-tag"><input type="checkbox" value="<%= s.name %>" /> <%= s.name %> (+Rp <%= s.price.toLocaleString("id-ID") %>)</label>
              <% }) %>
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- METODE LOGISTIK -->
      <div class="order-section">
        <h3 class="order-section-title">Metode Logistik</h3>
        <div class="logistics-grid">
          <!-- Pickup -->
          <div class="logistics-card" id="pickup-card">
            <div class="logistics-card-header">
              <i class="fa-solid fa-box-open"></i> Pengambilan (Pickup)
            </div>
            <div class="logistics-toggle">
              <button type="button" class="toggle-btn" data-group="pickup" data-value="self">
                Antar Sendiri
              </button>
              <button type="button" class="toggle-btn active" data-group="pickup" data-value="pickup">
                Pickup
              </button>
            </div>
            <div class="logistics-detail" id="pickup-detail">
              <span class="logistics-detail-label">PILIH ALAMAT JEMPUT (WAJIB)</span>
              <select class="form-input form-select" id="pickup-address-selector" style="margin-bottom: 10px;">
                <option value="">-- Pilih Alamat Profil --</option>
                <% if (user.addresses && user.addresses.length> 0) { %>
                  <% user.addresses.forEach(addr=> { %>
                    <option value="<%= addr.fullAddress %><%= addr.notes ? ' (' + addr.notes + ')' : '' %>" data-phone="<%= addr.phone || user.phone %>">
                      <%= addr.label.toUpperCase() %> - <%= addr.recipientName %>
                    </option>
                    <% }) %>
                <% } %>
                <option value="manual">-- Input Alamat Manual --</option>
              </select>
              <div id="pickup-address-manual-container" class="d-none">
                <textarea class="form-input" id="pickup-address-manual" placeholder="Masukkan alamat lengkap penjemputan..." rows="2"></textarea>
              </div>
            </div>
            <div class="logistics-detail d-none" id="pickup-self-info">
              <p class="logistics-info-note">
                <i class="fa-solid fa-store"></i> Silakan antar sepatu Anda ke gerai kami:<br>
                <strong><%= settings.storeInfo.name %></strong><br>
                <span style="font-size: 11px; opacity: 0.8;"><%= settings.storeInfo.address %></span>
              </p>
            </div>
          </div>
          <!-- Delivery -->
          <div class="logistics-card" id="delivery-card">
            <div class="logistics-card-header">
              <i class="fa-solid fa-truck"></i> Pengantaran (Delivery)
            </div>
            <div class="logistics-toggle">
              <button type="button" class="toggle-btn" data-group="delivery" data-value="self">
                Antar Sendiri
              </button>
              <button type="button" class="toggle-btn active" data-group="delivery" data-value="delivery">
                Delivery
              </button>
            </div>
            <div class="logistics-detail" id="delivery-detail">
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                <span class="logistics-detail-label" style="margin-bottom: 0;">PILIH ALAMAT ANTAR</span>
                <label
                  style="font-size: 0.75rem; color: var(--accent-color); cursor: pointer; display: flex; align-items: center; gap: 5px;">
                  <input type="checkbox" id="sync-address-checkbox"> Sama dengan Jemput
                </label>
              </div>

              <select class="form-input form-select" id="delivery-address-selector" style="margin-bottom: 10px;">
                <option value="">-- Pilih Alamat Profil --</option>
                <% if (user.addresses && user.addresses.length> 0) { %>
                  <% user.addresses.forEach(addr=> { %>
                    <option value="<%= addr.fullAddress %><%= addr.notes ? ' (' + addr.notes + ')' : '' %>" data-phone="<%= addr.phone || user.phone %>">
                      <%= addr.label.toUpperCase() %> - <%= addr.recipientName %>
                    </option>
                    <% }) %>
                <% } %>
                <option value="manual">-- Input Alamat Manual --</option>
              </select>
              <div id="delivery-address-manual-container" class="d-none">
                <textarea class="form-input" id="delivery-address-manual" placeholder="Masukkan alamat lengkap pengantaran..." rows="2"></textarea>
              </div>
            </div>
            <div class="logistics-detail d-none" id="delivery-self-info">
              <p class="logistics-info-note">
                <i class="fa-solid fa-store"></i> Silakan ambil sepatu Anda di gerai kami:<br>
                <strong><%= settings.storeInfo.name %></strong><br>
                <span style="font-size: 11px; opacity: 0.8;"><%= settings.storeInfo.address %></span>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- METODE PEMBAYARAN -->
      <div class="order-section">
        <h3 class="order-section-title">Metode Pembayaran</h3>
        <div class="payment-grid">
          <label class="payment-card active">
            <input type="radio" name="payment" value="bank" checked />
            <div class="payment-card-inner">
              <div class="payment-check">
                <i class="fa-solid fa-circle-check"></i>
              </div>
              <div class="payment-icon">
                <i class="fa-solid fa-building-columns"></i>
              </div>
              <span class="payment-name">Transfer Bank</span>
              <p class="payment-desc">
                Via Bisnis Indonesia. Keamanan & transfer bank digital
                terverifikasi.
              </p>
            </div>
          </label>
          <label class="payment-card">
            <input type="radio" name="payment" value="cod" />
            <div class="payment-card-inner">
              <div class="payment-check">
                <i class="fa-solid fa-circle-check"></i>
              </div>
              <div class="payment-icon">
                <i class="fa-solid fa-money-bill-wave"></i>
              </div>
              <span class="payment-name">COD (Bayar di Tempat)</span>
              <p class="payment-desc">
                Bayar saat kurir menjemput atau mengantar kembali sepatu Anda.
              </p>
            </div>
          </label>
        </div>
      </div>
    </div>

    <!-- RIGHT: ORDER SUMMARY -->
    <div class="order-summary-col">
      <div class="order-summary-card" id="order-summary">
        <h4 class="order-summary-title">Ringkasan Pesanan</h4>

        <div id="summary-items-container">
          <!-- Dynamic items will be inserted here -->
          <div class="order-summary-item placeholder-item">
            <p class="text-muted">Tambahkan sepatu untuk melihat ringkasan</p>
          </div>
        </div>

        <div class="order-summary-divider"></div>

        <div class="order-summary-row">
          <span>Subtotal</span>
          <span class="summary-price" id="summary-subtotal">Rp 0</span>
        </div>
        <div class="order-summary-row">
          <span>Biaya Jemput/Antar</span>
          <span class="summary-price" id="summary-logistics">Rp 0</span>
        </div>

        <div class="order-summary-estimate">
          <i class="fa-regular fa-clock"></i> ESTIMASI SELESAI
          <span class="estimate-badge">0 Hari</span>
        </div>

        <div class="order-summary-divider"></div>

        <div class="order-summary-row order-summary-total">
          <span>TOTAL PEMBAYARAN</span>
          <span class="summary-total-price" id="summary-total">Rp 0</span>
        </div>

        <button type="button" class="btn btn-primary btn-auth" id="btn-confirm-order">
          Konfirmasi Pesanan
        </button>
      </div>
    </div>
  </div>

  <%- include('../partials/dashboard-foot') %>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const btnConfirm = document.getElementById("btn-confirm-order");
      if (!btnConfirm) return;

      btnConfirm.addEventListener("click", async function(e) {
        e.preventDefault(); // Mencegah default action apapun

        // 1. Ambil Data Item
        const shoeItems = [];
        document.querySelectorAll(".shoe-item:not(#shoe-item-template .shoe-item)").forEach(item => {
          const nameEl = item.querySelector(".shoe-name");
          const serviceEl = item.querySelector(".service-type");
          if (!nameEl || !serviceEl) return;
          
          const name = nameEl.value;
          const serviceType = serviceEl.value;
          const addons = [];
          item.querySelectorAll(".addon-tag input:checked").forEach(cb => addons.push(cb.value));
          
          if (name && serviceType) {
            shoeItems.push({ shoeName: name, serviceType, addons });
          }
        });

        if (shoeItems.length === 0) {
          showCustomAlert("Item Kosong", "Silakan tambahkan setidaknya satu item sepatu.", "warning");
          return;
        }

        // 2. Ambil Data Logistik
        const pickupBtn = document.querySelector('[data-group="pickup"].active');
        const deliveryBtn = document.querySelector('[data-group="delivery"].active');
        const pickupMethod = pickupBtn ? pickupBtn.dataset.value : "self";
        const deliveryMethod = deliveryBtn ? deliveryBtn.dataset.value : "self";
        
        let pickupAddress = "";
        if (pickupMethod === "pickup") {
          const sel = document.getElementById("pickup-address-selector");
          pickupAddress = sel.value === "manual" ? document.getElementById("pickup-address-manual").value : sel.value;
          if (!pickupAddress) return showCustomAlert("Alamat Kurang", "Alamat jemput wajib diisi.", "warning");
        }

        let deliveryAddress = "";
        if (deliveryMethod === "delivery") {
          const sel = document.getElementById("delivery-address-selector");
          deliveryAddress = sel.value === "manual" ? document.getElementById("delivery-address-manual").value : sel.value;
          if (!deliveryAddress) return showCustomAlert("Alamat Kurang", "Alamat antar wajib diisi.", "warning");
        }

        // 3. Ambil Metode Pembayaran
        const paymentMethodEl = document.querySelector('input[name="payment"]:checked');
        const paymentMethod = paymentMethodEl ? paymentMethodEl.value : "bank";

        // 4. Kirim ke Server
        btnConfirm.disabled = true;
        btnConfirm.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Memproses...';

        try {
          const response = await fetch("/api/orders", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              items: shoeItems,
              logistics: { pickupMethod, deliveryMethod, pickupAddress, deliveryAddress },
              payment: { method: paymentMethod }
            })
          });

          const result = await response.json();

          if (result.status === "success") {
            if (paymentMethod === "bank") {
              if (result.data.snapToken) {
                console.log("Snap Token ditemukan:", result.data.snapToken);
                window.snap.pay(result.data.snapToken, {
                  onSuccess: function(res) { 
                    showCustomAlert("Berhasil", "Pembayaran Berhasil!", "success", () => {
                      window.location.href = "/customer/my-orders";
                    });
                  },
                  onPending: function(res) { 
                    // JANGAN redirect di sini agar popup VA/instruksi tetap terbuka
                    console.log("Payment pending:", res);
                  },
                  onError: function(res) { 
                    showCustomAlert("Gagal", "Pembayaran Gagal.", "error", () => {
                      window.location.href = "/customer/my-orders";
                    });
                  },
                  onClose: function() { 
                    // Hanya redirect setelah user menutup popup secara manual
                    window.location.href = "/customer/my-orders"; 
                  }
                });
              } else {
                showCustomAlert("Kesalahan Sistem", "Token Midtrans tidak ditemukan. Mengarahkan ke riwayat pesanan.", "error", () => {
                  window.location.href = "/customer/my-orders";
                });
              }
            } else {
              showCustomAlert("Berhasil", "Pesanan COD berhasil dibuat!", "success", () => {
                window.location.href = "/customer/my-orders";
              });
            }
          } else {
            showCustomAlert("Gagal", result.message, "error");
            btnConfirm.disabled = false;
            btnConfirm.innerHTML = "Konfirmasi Pesanan";
          }
        } catch (err) {
          console.error(err);
          showCustomAlert("Kesalahan", "Terjadi kesalahan koneksi.", "error");
          btnConfirm.disabled = false;
          btnConfirm.innerHTML = "Konfirmasi Pesanan";
        }
      });
    });
  </script>

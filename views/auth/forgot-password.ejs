<%- include('../partials/header') %>

  <!-- FORGOT PASSWORD PAGE -->
  <section class="auth-minimal-page">
    <div class="auth-minimal-card">
      <h1 class="auth-minimal-title">Atur Ulang Kata Sandi</h1>
      <p class="auth-minimal-desc">Masukkan email Anda untuk menerima instruksi pemulihan.</p>

      <form action="/forgot-password" method="POST" class="auth-form" id="forgot-form">
        <div class="form-input-wrap form-input-icon">
          <i class="fa-regular fa-envelope input-icon"></i>
          <input type="email" id="email" name="email" class="form-input form-input--icon" placeholder="nama@email.com"
            required />
        </div>

        <button type="submit" class="btn btn-primary btn-auth btn-auth--compact" id="btn-forgot">Kirim Link
          Pemulihan</button>
      </form>

      <a href="/login" class="auth-back-link">Kembali ke halaman Masuk</a>
      <p class="auth-switch">Belum menerima Email? <a href="#" class="auth-switch-link" id="resend-email">Kirim
          Ulang</a></p>
    </div>
  </section>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    const forgotForm = document.getElementById('forgot-form');
    const btnForgot = document.getElementById('btn-forgot');

    forgotForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;

      btnForgot.disabled = true;
      btnForgot.textContent = 'Mengirim...';

      try {
        const res = await fetch('/api/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await res.json();

        if (data.status === 'success') {
          Swal.fire({
            icon: 'success',
            title: 'Email Terkirim!',
            text: 'Silakan cek email Anda untuk instruksi pemulihan.',
            confirmButtonColor: '#efb140'
          });
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Gagal',
            text: data.message,
            confirmButtonColor: '#efb140'
          });
        }
      } catch (err) {
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: 'Terjadi kesalahan pada server. Silakan coba lagi nanti.',
          confirmButtonColor: '#efb140'
        });
      } finally {
        btnForgot.disabled = false;
        btnForgot.textContent = 'Kirim Link Pemulihan';
      }
    });

    document.getElementById('resend-email').addEventListener('click', (e) => {
      e.preventDefault();
      forgotForm.dispatchEvent(new Event('submit'));
    });
  </script>

  <%- include('../partials/footer') %>
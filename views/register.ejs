<%- include('partials/header') %>

<!-- REGISTER PAGE -->
<section class="auth-page">
  <div class="auth-layout">
    <!-- Left: Hero Image Section -->
    <div class="auth-hero">
      <img src="/images/auth-register.png" alt="Goede Shoes" class="auth-hero-img" />
      <div class="auth-hero-overlay"></div>
      <div class="auth-hero-content">
        <span class="auth-hero-label">KUALITAS TANPA KOMPROMI</span>
        <h2 class="auth-hero-title">Setiap Langkah Adalah <br>Pernyataan.</h2>
        <p class="auth-hero-desc">Di Goede, kami tidak hanya membersihkan sepatu, kami merestorasi kepercayaan diri Anda melalui presisi yang tak tertanding.</p>
      </div>
    </div>

    <!-- Right: Form Section -->
    <div class="auth-form-section">
      <div class="auth-form-wrapper">
        <h1 class="auth-form-title">Buat Akun</h1>
        <p class="auth-form-subtitle">Bergabunglah dengan standar baru dalam perawatan sepatu eksklusif.</p>

        <form action="/register" method="POST" class="auth-form" id="register-form">
          <!-- Nama Lengkap -->
          <div class="form-group">
            <label for="nama" class="form-label">Nama Lengkap</label>
            <div class="form-input-wrap">
              <input type="text" id="nama" name="nama" class="form-input" placeholder="John Doe" required />
            </div>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <div class="form-input-wrap">
              <input type="email" id="email" name="email" class="form-input" placeholder="nama@email.com" required />
            </div>
          </div>

          <!-- Nomor Telepon -->
          <div class="form-group">
            <label for="phone" class="form-label">Nomor Telepon</label>
            <div class="form-input-wrap">
              <input type="tel" id="phone" name="phone" class="form-input" placeholder="+62 812 3456 7890" required />
            </div>
          </div>

          <!-- Kata Sandi -->
          <div class="form-group">
            <label for="password" class="form-label">Kata Sandi</label>
            <div class="form-input-wrap">
              <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required />
            </div>
          </div>

          <!-- Ulangi Kata Sandi -->
          <div class="form-group">
            <label for="confirmPassword" class="form-label">Ulangi Kata Sandi</label>
            <div class="form-input-wrap">
              <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" placeholder="••••••••" required />
            </div>
          </div>

          <!-- Alamat -->
          <div class="form-group">
            <label for="alamat" class="form-label">Alamat</label>
            <div class="form-input-wrap">
              <textarea id="alamat" name="alamat" class="form-input form-textarea" placeholder="Masukkan alamat lengkap Anda..." rows="3" required></textarea>
            </div>
          </div>

          <!-- Terms Checkbox -->
          <div class="form-check">
            <input type="checkbox" id="terms" name="terms" class="form-checkbox" required />
            <label for="terms" class="form-check-label">
              Saya setuju dengan <a href="#" class="form-link">Syarat & Ketentuan</a> serta kebijakan <a href="#" class="form-link">Privasi Goede</a>
            </label>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn btn-primary btn-auth" id="btn-register">Daftar Sekarang</button>
        </form>

        <p class="auth-switch">Sudah punya akun? <a href="/login" class="auth-switch-link">Masuk</a></p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

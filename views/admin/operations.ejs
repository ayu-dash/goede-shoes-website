<%- include('../partials/dashboard-head') %>

  <div class="page-header" style="margin-bottom: 32px">
    <h1 class="page-title page-title--xl">Manajemen Operasional</h1>
  </div>

  <div class="ops-layout">
    <!-- LEFT COLUMN -->
    <div class="ops-left" style="position: sticky; top: 24px; align-self: start;">

      <!-- TARIF PENGIRIMAN -->
      <div class="admin-panel ops-tarif-section">
        <h4 class="ops-section-label">TARIF PENGIRIMAN</h4>
        <div class="ops-tarif-display">
          <span class="ops-tarif-value" id="displayTarif">Rp <%= settings.shippingRatePerKm.toLocaleString('id-ID') %>
              </span>
          <span class="ops-tarif-unit">/km</span>
        </div>
        <button class="ops-edit-tarif-btn" onclick="openModal('editTarifModal')">
          <i class="fa-solid fa-pen"></i> Edit Tarif
        </button>
      </div>

      <!-- ABOUT FOOTER -->
      <div class="admin-panel ops-about-section" style="margin-top: 24px">
        <h4 class="ops-section-label">ABOUT FOOTER</h4>
        <div class="ops-form-group">
          <div class="ops-field-value-box" style="height: auto; min-height: 80px; font-size: 12px; line-height: 1.6; white-space: pre-wrap; background: #f8fafc; border-color: #e2e8f0;"><%= settings.aboutText || 'Belum diatur' %></div>
        </div>
        <button class="ops-edit-tarif-btn" style="margin-top: 12px; width: 100%; justify-content: center;" onclick="openModal('aboutModal')">
          <i class="fa-solid fa-pen"></i> Edit Teks
        </button>
      </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="ops-right">
      <div class="admin-panel ops-store-section" id="storePanel">
        <h4 class="ops-section-label">LOKASI TOKO</h4>

        <!-- View Mode -->
        <div class="ops-store-view" id="storeViewMode">
          <div class="ops-form-group">
            <label class="ops-field-label">NAMA TOKO</label>
            <div class="ops-field-value-box">
              <%= settings.storeInfo.name %>
            </div>
          </div>

          <div class="ops-form-group">
            <label class="ops-field-label">ALAMAT TOKO</label>
            <div class="ops-field-value-box">
              <%= settings.storeInfo.address %>
            </div>
          </div>

          <div class="ops-form-row">
            <div class="ops-form-group">
              <label class="ops-field-label">WAKTU BUKA</label>
              <div class="ops-field-value-box ops-field-icon-right">
                <%= settings.storeInfo.openTime %>
                  <i class="fa-regular fa-clock"></i>
              </div>
            </div>
            <div class="ops-form-group">
              <label class="ops-field-label">WAKTU TUTUP</label>
              <div class="ops-field-value-box ops-field-icon-right">
                <%= settings.storeInfo.closeTime %>
                  <i class="fa-regular fa-clock"></i>
              </div>
            </div>
          </div>

          <div class="ops-form-row">
            <div class="ops-form-group">
              <label class="ops-field-label">NOMOR TELEPON</label>
              <div class="ops-field-value-box ops-field-icon-right">
                <%= settings.storeInfo.phone %>
                  <i class="fa-solid fa-phone"></i>
              </div>
            </div>
            <div class="ops-form-group">
              <label class="ops-field-label">ALAMAT EMAIL</label>
              <div class="ops-field-value-box ops-field-icon-right">
                <%= settings.storeInfo.email %>
                  <i class="fa-regular fa-envelope"></i>
              </div>
            </div>
          </div>


          <!-- Map -->
          <div class="ops-map-container"
            style="height: 300px; border-radius: 12px; overflow: hidden; margin-top: 20px; margin-bottom: 20px;">
            <iframe width="100%" height="100%" frameborder="0" style="border:0"
              src="https://maps.google.com/maps?q=<%= encodeURIComponent(settings.storeInfo.address) %>&t=&z=15&ie=UTF8&iwloc=&output=embed"
              allowfullscreen>
            </iframe>
          </div>
          <button class="btn btn-primary" style="width: 100%; justify-content: center; background: #0d47a1;"
            onclick="toggleEditMode(true)">
            <i class="fa-solid fa-pen-to-square" style="margin-right: 8px;"></i> Edit Info Toko
          </button>
        </div>

        <!-- Edit Mode -->
        <form id="storeSettingsForm" onsubmit="saveStoreSettings(event)">
          <div class="ops-store-edit" id="storeEditMode" style="display: none">
            <div class="ops-form-group">
              <label class="ops-field-label">NAMA TOKO</label>
              <input type="text" name="name" class="ops-field-input" value="<%= settings.storeInfo.name %>" required />
            </div>

            <div class="ops-form-group">
              <label class="ops-field-label">ALAMAT TOKO</label>
              <input type="text" name="address" class="ops-field-input" value="<%= settings.storeInfo.address %>"
                required />
            </div>

            <div class="ops-form-row">
              <div class="ops-form-group">
                <label class="ops-field-label">WAKTU BUKA</label>
                <div class="ops-field-input-icon">
                  <input type="time" name="openTime" class="ops-field-input" value="<%= settings.storeInfo.openTime %>"
                    required />
                  <i class="fa-regular fa-clock"></i>
                </div>
              </div>
              <div class="ops-form-group">
                <label class="ops-field-label">WAKTU TUTUP</label>
                <div class="ops-field-input-icon">
                  <input type="time" name="closeTime" class="ops-field-input"
                    value="<%= settings.storeInfo.closeTime %>" required />
                  <i class="fa-regular fa-clock"></i>
                </div>
              </div>
            </div>

            <div class="ops-form-row">
              <div class="ops-form-group">
                <label class="ops-field-label">NOMOR TELEPON</label>
                <div class="ops-field-input-icon">
                  <input type="tel" name="phone" class="ops-field-input" value="<%= settings.storeInfo.phone %>"
                    required />
                  <i class="fa-solid fa-phone"></i>
                </div>
              </div>
              <div class="ops-form-group">
                <label class="ops-field-label">ALAMAT EMAIL</label>
                <div class="ops-field-input-icon">
                  <input type="email" name="email" class="ops-field-input" value="<%= settings.storeInfo.email %>"
                    required />
                  <i class="fa-regular fa-envelope"></i>
                </div>
              </div>
            </div>


            <div class="ops-map-container"
              style="height: 150px; background: #f8f9fa; border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 2px dashed #cbd5e1; margin-top: 20px;">
              <div style="text-align: center; color: var(--text-secondary);">
                <i class="fa-solid fa-map-location-dot" style="font-size: 24px; margin-bottom: 8px;"></i>
                <p style="font-size: 11px; font-weight: 600;">Peta akan diperbarui otomatis setelah alamat disimpan</p>
              </div>
            </div>
            <div class="ops-edit-actions" style="margin-top: 20px;">
              <button type="button" class="btn btn-ghost-cancel" onclick="toggleEditMode(false)">
                Batal
              </button>
              <button type="submit" class="btn btn-primary">
                <i class="fa-regular fa-circle-check"></i> Simpan Perubahan
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ==================== MODALS ==================== -->


  <!-- Modal About Footer -->
<div class="modal-overlay" id="aboutModal" onclick="closeModal(event, 'aboutModal')">
  <div class="modal-content" style="max-width: 500px; padding: 32px">
    <h3 class="modal-title" style="color: #0d47a1; margin-bottom: 8px; font-size: 20px">About Footer</h3>
    <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 24px;">Teks ini akan muncul di bagian bawah website (footer).</p>
    
    <form onsubmit="saveAboutText(event)">
      <div class="modal-form-group" style="margin-bottom: 24px">
        <label class="modal-label">TEKS ABOUT</label>
        <textarea name="aboutText" class="modal-input" style="width: 100%; height: 150px; resize: vertical; padding: 12px; font-family: inherit; font-size: 13px;" required><%= settings.aboutText %></textarea>
      </div>
      <div class="modal-actions" style="justify-content: flex-end; gap: 16px">
        <button type="button" class="btn btn-ghost-cancel" onclick="closeModalRaw('aboutModal')">Batal</button>
        <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
      </div>
    </form>
  </div>
</div>
  <div class="modal-overlay" id="editTarifModal" onclick="closeModal(event, 'editTarifModal')">
    <div class="modal-content" style="max-width: 400px; padding: 32px">
      <h3 class="modal-title" style="color: #0d47a1; margin-bottom: 24px; font-size: 20px">
        Edit Tarif Pengiriman
      </h3>
      <form onsubmit="saveShippingRate(event)">
        <div class="modal-form-group" style="margin-bottom: 24px">
          <label class="modal-label">TARIF PER KM (Rp)</label>
          <input type="number" id="inputTarif" class="modal-input" value="<%= settings.shippingRatePerKm %>" required />
        </div>
        <div class="modal-actions" style="justify-content: flex-end; gap: 16px">
          <button type="button" class="btn btn-ghost-cancel" style="font-weight: 700"
            onclick="closeModalRaw('editTarifModal')">
            Batal
          </button>
          <button type="submit" class="btn btn-primary" style="background: #0d47a1; border-radius: 8px">
            Simpan
          </button>
        </div>
      </form>
    </div>
  </div>



  <script>

    function toggleEditMode(isEditing) {
      document.getElementById("storeViewMode").style.display = isEditing
        ? "none"
        : "block";
      document.getElementById("storeEditMode").style.display = isEditing
        ? "block"
        : "none";
    }

    function openModal(id) {
      const modal = document.getElementById(id);
      if (modal) {
        modal.classList.add("active");
      } else {
        console.error('Modal with ID ' + id + ' not found');
      }
    }
    function closeModal(e, id) {
      if (e.target.id === id) {
        document.getElementById(id).classList.remove("active");
      }
    }
    function closeModalRaw(id) {
      document.getElementById(id).classList.remove("active");
    }

    async function saveStoreSettings(e) {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = {
        storeInfo: {
          name: formData.get('name'),
          address: formData.get('address'),
          openTime: formData.get('openTime'),
          closeTime: formData.get('closeTime'),
          phone: formData.get('phone'),
          email: formData.get('email')
        }
      };

      try {
        const res = await fetch('/api/admin/settings', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        if (res.ok) {
          showCustomAlert("Berhasil", "Pengaturan toko telah diperbarui.", "success", () => {
            location.reload();
          });
        } else {
          showCustomAlert("Gagal", "Gagal menyimpan perubahan pengaturan toko.", "error");
        }
      } catch (err) {
        showCustomAlert("Error", "Terjadi kesalahan koneksi.", "error");
      }
    }

    async function saveShippingRate(e) {
      e.preventDefault();
      const rate = document.getElementById('inputTarif').value;

      try {
        const res = await fetch('/api/admin/settings', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ shippingRatePerKm: rate })
        });
        if (res.ok) {
          showCustomAlert("Berhasil", "Tarif pengiriman telah diperbarui.", "success", () => {
            location.reload();
          });
        } else {
          showCustomAlert("Gagal", "Gagal menyimpan tarif pengiriman.", "error");
        }
      } catch (err) {
        showCustomAlert("Error", "Terjadi kesalahan koneksi.", "error");
      }
    }


    async function saveAboutText(e) {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = {
      aboutText: formData.get('aboutText')
    };

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      if (res.ok) {
        showCustomAlert("Berhasil", "Teks About Footer telah disimpan.", "success", () => {
          location.reload();
        });
      } else {
        showCustomAlert("Gagal", "Gagal menyimpan teks About.", "error");
      }
    } catch (err) {
      showCustomAlert("Error", "Terjadi kesalahan koneksi.", "error");
    }
  }
</script>

  <%- include('../partials/dashboard-foot') %>